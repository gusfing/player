generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  clerkId             String    @unique
  email               String    @unique
  name                String?
  tier                String    @default("free")
  stripeCustomerId    String?   @unique
  stripeSubId         String?

  masterApiKey        String    @unique @default(cuid())

  globalBrandingConfig Json     @default("{}")
  globalCtaConfig      Json     @default("{}")
  globalMetaPixelId   String?
  globalWatermarkUrl  String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  installations       Installation[]
  leads               LeadCapture[]
  webhooks            Webhook[]
  googleAnalytics     GoogleAnalytics?
  videos              Video[]
  folders             Folder[]
}

model Installation {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  domain              String
  platform            String    // "wordpress" | "shopify" | "custom"
  status              String    @default("pending")  // "pending" | "active" | "disconnected" | "deleted"
  
  apiKey              String    @unique
  
  brandingConfig      Json      @default("{}")
  ctaConfig           Json      @default("{}")
  metaPixelId         String?
  googleAnalyticsId   String?
  debugMode           String    @default("inherit")  // "inherit" | "enabled" | "disabled"
  
  allowedDomains      Json      @default("[]")  // Array of domains
  
  totalPlays          Int       @default(0)
  totalViews          Int       @default(0)
  
  pluginVersion       String?
  lastHeartbeatAt     DateTime?
  lastActivityAt      DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  analytics           SiteAnalytics[]
  leads               LeadCapture[]
  videos              Video[]

  @@unique([userId, domain])
  @@index([userId, status])
  @@index([lastHeartbeatAt])
  @@index([apiKey])
}

model SiteAnalytics {
  id                  String    @id @default(cuid())
  installationId      String
  installation        Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  
  eventType           String    // "video_played", "video_progress", etc
  youtubeVideoId      String?
  youtubeUrl          String?
  
  viewerId            String?
  anonymousId         String?
  
  currentTime         Int?
  duration            Int?
  watchPercent        Float?
  
  ipHash              String?
  userAgent           String?
  deviceType          String?
  country             String?
  
  referrer            String?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  
  metadata            Json?
  
  createdAt           DateTime  @default(now())

  @@index([installationId, createdAt])
}

model LeadCapture {
  id                  String    @id @default(cuid())
  installationId      String
  installation        Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  email               String
  name                String?
  customFields        Json?
  
  submissionCount     Int       @default(1)
  lastSubmittedAt     DateTime  @default(now())
  
  ipHash              String?
  userAgent           String?
  
  createdAt           DateTime  @default(now())
  
  @@unique([installationId, email])
  @@index([installationId, createdAt])
}

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name      String
  url       String
  secret    String   // Auto-generated HMAC secret
  events    String[] // ["video_played", "lead_captured", etc]
  enabled   Boolean  @default(true)
  
  consecutiveFailures Int  @default(0)
  lastFailureAt     DateTime?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  deliveries WebhookDelivery[]
  stats     WebhookStats?
  
  @@index([userId])
  @@index([userId, enabled])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  event       String
  payload     Json
  status      String   // "pending" | "success" | "failed"
  attempts    Int      @default(0)
  lastError   String?
  
  createdAt   DateTime @default(now())
  
  @@index([webhookId, createdAt])
  @@index([webhookId, status])
}

model WebhookStats {
  id            String   @id @default(cuid())
  webhookId     String   @unique
  webhook       Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  
  lastStatus    String?
  lastAttempt   DateTime?
  
  @@index([webhookId])
}

model GoogleAnalytics {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  measurementId   String   // G-XXXXXXXXXX
  apiSecret       String   // GA4 Measurement Protocol API secret
  
  enabled         Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Video {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  installationId      String?
  installation        Installation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  youtubeVideoId      String
  title               String
  thumbnailUrl        String?
  customThumbnailUrl  String?
  duration            Int?

  folderId            String?
  folder              Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  tags                String[]  @default([])

  playerConfig        Json      @default("{}")
  gateConfig          Json?

  totalViews          Int       @default(0)
  totalLeads          Int       @default(0)
  retentionData       Json?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId, youtubeVideoId])
  @@index([userId, folderId])
  @@index([userId])
  @@index([youtubeVideoId])
}

model Folder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  color       String   @default("#6366f1")
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videos      Video[]

  @@unique([userId, name])
  @@index([userId])
}
